local function createToggleButton(imageAsset)
    if getgenv().OpenGuiButton then getgenv().OpenGuiButton:Destroy() end
    
    local gui = Instance.new("ScreenGui")
    gui.Name = "ToggleGui_Kaprao"
    gui.Parent = (gethui and gethui()) or player:WaitForChild("PlayerGui")
    gui.IgnoreGuiInset = true
    gui.ResetOnSpawn = false
    
    local frame = Instance.new("Frame", gui)
    frame.Size = UDim2.new(0, 35, 0, 35)
    frame.Position = UDim2.new(0, 20, 0, 150)
    frame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    frame.BackgroundTransparency = 0.1
    frame.Active = true
    
    local corner = Instance.new("UICorner", frame)
    corner.CornerRadius = UDim.new(0, 8) 
    
    local btn = Instance.new("ImageButton", frame)
    btn.Size = UDim2.new(0, 23, 0, 23)
    btn.Position = UDim2.new(0, 6, 0, 6)
    btn.BackgroundTransparency = 1
    btn.Image = imageAsset
    
    local dragging, dragStart, startPos
    local hasDragged = false
    
    btn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            hasDragged = false
        end
    end)

    UIS.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            if delta.Magnitude > 7 then hasDragged = true end
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)

    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    btn.Activated:Connect(function()
        if not hasDragged then
            local customToggleUsed = false
            pcall(function()
                if Window and Window.Toggle then
                    Window:Toggle()
                    customToggleUsed = true
                end
            end)
            if not customToggleUsed then
                for _, v in pairs(game:GetService("CoreGui"):GetChildren()) do
                    if v:IsA("ScreenGui") and (v.Name == "WindUI" or v:FindFirstChild("Main") or string.find(v.Name, "Wind")) then
                        v.Enabled = not v.Enabled
                    end
                end
                for _, v in pairs(player:WaitForChild("PlayerGui"):GetChildren()) do
                    if v:IsA("ScreenGui") and (v.Name == "WindUI" or v:FindFirstChild("Main") or string.find(v.Name, "Wind")) then
                        v.Enabled = not v.Enabled
                    end
                end
            end
        end
    end)
    
    getgenv().OpenGuiButton = gui
end

