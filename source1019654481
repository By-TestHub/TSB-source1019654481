RunService.Heartbeat:Connect(function()
    if spinActive and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local root = LocalPlayer.Character.HumanoidRootPart
        local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        local oldRotVel = root.RotVelocity
        root.RotVelocity = Vector3.new(0, spinSpeed, 0)
        
        RunService.RenderStepped:Wait()
        root.RotVelocity = oldRotVel
        if hum then
            if hum:GetState() == Enum.HumanoidStateType.FallingDown or hum:GetState() == Enum.HumanoidStateType.Ragdoll then
                hum:ChangeState(Enum.HumanoidStateType.GettingUp)
            end
        end
    end
end)

local function SetOtherPlayersCollision(canCollideStatus)
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            for _, part in ipairs(p.Character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = canCollideStatus
                end
            end
        end
    end
end

RunService.Stepped:Connect(function()
    if playerAntiFling then
        SetOtherPlayersCollision(false)
    end
end)

